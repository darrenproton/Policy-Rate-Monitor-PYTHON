.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Environment / secrets
.env

# Downloaded data (large bulk files — don't commit)
data/
*.zip
*.csv

# IDE / OS
.idea/
.vscode/
.DS_Store

