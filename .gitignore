*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Generated outputs are gitignored, except the showcase images referenced in the docs.
out/*
!out/speech-testing/
out/speech-testing/*
!out/speech-testing/covid-2020-leadlag_policy_rates.png
!out/speech-testing/covid-terms_policy_rates.png
